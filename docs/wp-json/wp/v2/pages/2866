asse 17, 53111 Bonn<\/p>\n\n\n\n<p>Mail: info@beethovenhoteldreesen.de<\/p>\n\n\n\n<p>\u260f: +49 228 6297520<\/p>\n\n\n\n<p>Website: <a href=\"https:\/\/www.beethovenhoteldreesen.de\/de\">Home (beethovenhoteldreesen.de)<\/a><\/p>\n\n\n\n<p><\/p>\n\n\n\n<ul>\n<li><strong>Hotel Aigner<\/strong><\/li>\n<\/ul>\n\n\n\n<p>~75\u20ac, Nordstadt Bonn. Dorotheenstr. 12, 53111 Bonn<strong> <\/strong><strong><\/strong><\/p>\n\n\n\n<p>Mail: hotel-aigner@t-online.de<\/p>\n\n\n\n<p>\u260f: +49 228 604060<\/p>\n\n\n\n<p>Website: <a href=\"https:\/\/www.hotel-aigner-bonn.de\/\">Hotel Aigner Bonn (hotel-aigner-bonn.de)<\/a><\/p>\n\n\n\n<p><\/p>\n\n\n\n<p><\/p>\n<\/div>","protected":false},"excerpt":{"rendered":"<p>Venue How to get to Bonn How to get to the venue Hotels and accommodation shortlist Dear Guests,&nbsp; We are pleased to welcome you to the final Gotriple Conference in Bonn. We want to share some travel information to make<\/p>\n","protected":false},"author":16,"featured_media":0,"parent":312,"menu_order":1,"comment_status":"closed","ping_status":"closed","template":"","meta":[],"_links":{"self":[{"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/pages\/2866"}],"collection":[{"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/users\/16"}],"replies":[{"embeddable":true,"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/comments?post=2866"}],"version-history":[{"count":20,"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/pages\/2866\/revisions"}],"predecessor-version":[{"id":3198,"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/pages\/2866\/revisions\/3198"}],"up":[{"embeddable":true,"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/pages\/312"}],"wp:attachment":[{"href":"https:\/\/project.gotriple.eu\/wp-json\/wp\/v2\/media?parent=2866"}],"curies":[{"name":"wp","href